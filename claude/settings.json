{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": false,
    "figma@claude-plugins-official": false,
    "opgg-essentials@opgg-plugins": true,
    "claude-mem@thedotmack": true,
    "ralph-loop@claude-plugins-official": true,
    "ralph-wiggum@claude-code-plugins": true,
    "skill-creator@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "documents@socoolbear-cc-marketplace": true,
    "harness@socoolbear-cc-marketplace": true,
    "phpstorm-plugin@phpstorm-marketplace": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "socoolbear-cc-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/socoolbear/cc-marketplace.git"
      }
    },
    "phpstorm-marketplace": {
      "source": {
        "source": "github",
        "repo": "jetbrains/phpstorm-claude-marketplace"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "plansDirectory": ".claude/plan"
}
