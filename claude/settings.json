{
  "skillListingBudgetFraction": 0.02,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_PACKAGE_MANAGER_AUTO_UPDATE": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/enforce-cli-tools.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/scripts/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "documents@socoolbear-cc-marketplace": true,
    "harness@socoolbear-cc-marketplace": true,
    "phpstorm-plugin@phpstorm-marketplace": true,
    "snippets@socoolbear-cc-marketplace": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      },
      "autoUpdate": true
    },
    "socoolbear-cc-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/socoolbear/cc-marketplace.git"
      },
      "autoUpdate": true
    },
    "phpstorm-marketplace": {
      "source": {
        "source": "github",
        "repo": "jetbrains/phpstorm-claude-marketplace"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "high",
  "plansDirectory": ".claude/plan",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
