# Ghostty Configuration
# https://ghostty.org/docs/config

# Custom environment variable for terminal detection (used in zshrc)
env = GHOSTTY_TERMINAL=true

# Shift+Enter를 줄바꿈으로 매핑 (tmux 내에서 작동하도록)
keybind = shift+enter=text:\x1b\r

# 이모지 및 특수문자 너비를 엄격하게 2칸으로 지정
grapheme-width-method = "unicode"

font-family = "JetBrainsMono Nerd Font"
font-size = 14