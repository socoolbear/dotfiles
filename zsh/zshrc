is_intellij_terminal() {
    [[ -n "$INTELLIJ_ENVIRONMENT_READER" || -n "$FIG_JETBRAINS_SHELL_INTEGRATION" || -n "$TERMINAL_EMULATOR" ]]
}

#--------------------------------------------------------------------------
# Oh My Zsh
#--------------------------------------------------------------------------

export ZSH=$HOME/.oh-my-zsh
ZSH_THEME=""
export ZSH_TMUX_AUTOSTART=false
HYPHEN_INSENSITIVE="true"
COMPLETION_WAITING_DOTS="true"
HIST_STAMPS="yyyy-mm-dd"

plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
    docker
    docker-compose
    npm
    fzf
    composer
    httpie
)

# ghostty 터미널에서 tmux 자동 시작 (IntelliJ 내장 터미널은 제외 — env 가 상속되어 오탐됨)
if [[ -n "$GHOSTTY_TERMINAL" ]] && ! is_intellij_terminal; then
    export ZSH_TMUX_AUTOSTART=true
    plugins+=(tmux)
    [[ -o login ]] && cd $HOME/code
fi

# Idea 예외처리
if is_intellij_terminal; then
    path=(
        $HOME/.yarn/bin
        $HOME/.config/yarn/global/node_modules/.bin
        "$HOME/Library/Application Support/Herd/bin/"
        $path
    )
fi

source $ZSH/oh-my-zsh.sh

#--------------------------------------------------------------------------
# Configuration
#--------------------------------------------------------------------------
typeset -U PATH path cdpath fpath

export HOMEBREW_AUTO_UPDATE_SECS="86400"
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
export ANDROID_HOME=$HOME/Library/Android/sdk

path=(
    /usr/local/bin
    /usr/bin
    /bin
    /usr/sbin
    /sbin
    $HOME/.local/bin
    $HOME/.config/composer/vendor/bin
    $HOME/.cargo/bin
    ./vendor/bin
    ${ANDROID_HOME}/emulator
    ${ANDROID_HOME}/platform-tools
    /opt/homebrew/opt/mysql/bin
    /opt/homebrew/opt/mysql-client/bin
    /opt/homebrew/opt/libpq/bin
    $path
)

setopt auto_cd
cdpath=(
    $HOME/code
)

export EDITOR=vim
export GIT_EDITOR=vim
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

unsetopt sharehistory

#--------------------------------------------------------------------------
# Aliases
#--------------------------------------------------------------------------
alias k='kubectl'
alias he='helm'
alias sail='[ -f sail ] && bash sail || bash vendor/bin/sail'
alias pn='pnpm'
alias cc='claude --dangerously-skip-permissions'

[ -x "$(command -v bat)" ] && alias cat="bat --paging=never" || alias cat="batcat --paging=never"

[ -x "$(command -v eza)" ] && {
    alias ls='eza --group-directories-first'
    alias ll='eza -l --git --group-directories-first'
    alias la='eza -la --git --group-directories-first'
    alias lt='eza --tree --level=2'
}

[ -x "$(command -v lazygit)" ] && alias lg='lazygit'
[ -x "$(command -v yazi)" ] && alias yz='yazi'


#--------------------------------------------------------------------------
# Claude & Claude Code
#--------------------------------------------------------------------------
export CLAUDE_CODE_EFFORT_LEVEL=max

#--------------------------------------------------------------------------
# Miscellaneous
#--------------------------------------------------------------------------
[ -f ~/.private-exports ] && source $HOME/.private-exports

bindkey "^[[1;3C" forward-word
bindkey "^[[1;3D" backward-word

export LANG=en_US.UTF-8 # k9s 깨짐 문제 해결

# bun
export BUN_RUNTIME_TRANSPILER_CACHE_PATH=/tmp/bun-cache
export BUN_INSTALL_CACHE_DIR=/tmp/bun-cache
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# mise — Node, Go 등 통합 버전 관리 (nvm/rbenv 대체). PATH prepend 하므로 기존 PATH 설정 이후에 호출.
eval "$(mise activate zsh)"

alias claude-mem='bun "$HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"'

# tools
eval "$(zoxide init zsh)"
eval "$(atuin init zsh --disable-up-arrow)"
eval "$(starship init zsh)"
